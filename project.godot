; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Reference",
"class": "CameraState",
"language": "GDScript",
"path": "res://Script/fnaf_movement/CameraState.gd"
}, {
"base": "Node",
"class": "DoorInputHandler",
"language": "GDScript",
"path": "res://Script/rolling_door/DoorInputHandler.gd"
}, {
"base": "Reference",
"class": "DoorMotionController",
"language": "GDScript",
"path": "res://Script/rolling_door/DoorMotionController.gd"
}, {
"base": "Spatial",
"class": "DoorObstacleDetector",
"language": "GDScript",
"path": "res://Script/rolling_door/DoorObstacleDetector.gd"
}, {
"base": "Reference",
"class": "DoorState",
"language": "GDScript",
"path": "res://Script/rolling_door/DoorState.gd"
}, {
"base": "Reference",
"class": "Easing",
"language": "GDScript",
"path": "res://Script/utils/Easing.gd"
}, {
"base": "EditorVCSInterface",
"class": "GitAPI",
"language": "NativeScript",
"path": "res://addons/godot-git-plugin/git_api.gdns"
}, {
"base": "Reference",
"class": "LookDownDetector",
"language": "GDScript",
"path": "res://Script/fnaf_movement/LookDownDetector.gd"
}, {
"base": "Reference",
"class": "MouseLookController",
"language": "GDScript",
"path": "res://Script/fnaf_movement/MouseLookController.gd"
}, {
"base": "Reference",
"class": "ViewTransitioner",
"language": "GDScript",
"path": "res://Script/fnaf_movement/ViewTransitioner.gd"
} ]
_global_script_class_icons={
"CameraState": "",
"DoorInputHandler": "",
"DoorMotionController": "",
"DoorObstacleDetector": "",
"DoorState": "",
"Easing": "",
"GitAPI": "",
"LookDownDetector": "",
"MouseLookController": "",
"ViewTransitioner": ""
}

[application]

config/name="FNAF"
run/main_scene="res://scene/Spatial.tscn"
config/icon="res://icon.png"

[editor]

version_control_autoload_on_startup=true
version_control_plugin_name="GitAPI"

[gdnative]

singletons=[  ]

[gui]

common/drop_mouse_on_gui_input_disabled=true

[physics]

common/enable_pause_aware_picking=true

[rendering]

environment/default_environment="res://default_env.tres"
